# RIR Support Configuration
SUPPORT_RIPE=true
SUPPORT_ARIN=true
SUPPORT_APNIC=true
SUPPORT_AFRINIC=true
SUPPORT_LACNIC=true

# Auth profile. Use production or test. production is the default.
INET_REGISTRY_MCP_PROFILE=production

# Authenticated read-only RIPE support.
# RIPE_API_KEY is for RIPE Database REST API object lookup, maintained-object inventory, and audit.
RIPE_API_KEY=

# Authenticated read-only ARIN support.
ARIN_API_KEY=
ARIN_INVENTORY_ORG_HANDLES=
ARIN_INVENTORY_NET_HANDLES=
ARIN_INVENTORY_POC_HANDLES=
ARIN_INVENTORY_CUSTOMER_HANDLES=
ARIN_INVENTORY_DELEGATION_NAMES=
ARIN_INVENTORY_TICKET_NUMBERS=

# Future provider-specific authenticated API support.
APNIC_ACCESS_TOKEN=
APNIC_CLIENT_ID=
APNIC_CLIENT_SECRET=
LACNIC_ACCESS_TOKEN=
LACNIC_CLIENT_ID=
LACNIC_CLIENT_SECRET=

# Optional authenticated endpoint overrides for local/test targets.
RIPE_DATABASE_REST_BASE=
ARIN_REG_REST_BASE=
APNIC_REGISTRY_BASE=
LACNIC_REGISTRATION_BASE=

# General Configuration
HTTP_TIMEOUT_SECONDS=10
WHOIS_CONNECT_TIMEOUT_SECONDS=5
WHOIS_READ_TIMEOUT_SECONDS=5
CACHE_TTL_SECONDS=60
CACHE_MAX_ITEMS=512

# Custom User-Agent (optional)
USER_AGENT=inet-registry-mcp/1.0

# HTTP transport configuration
HTTP_HOST=127.0.0.1
HTTP_PORT=8000
