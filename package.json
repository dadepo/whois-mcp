{
  "name": "whois-mcp-typescript-port",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "whois-mcp": "./bin/whois-mcp.js",
    "whois-mcp-server": "./bin/whois-mcp-server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node bin/choose-transport.js dev",
    "dev:stdio": "tsx ts/src/index.ts",
    "dev:http": "tsx ts/src/http.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "tsx": "^4.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
