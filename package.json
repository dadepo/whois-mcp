{
  "name": "inet-registry-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server for Internet registry and registry-adjacent data used by network operators.",
  "type": "module",
  "bin": {
    "inet-registry-mcp": "./bin/inet-registry-mcp.js",
    "inet-registry-mcp-server": "./bin/inet-registry-mcp-server.js"
  },
  "keywords": [
    "mcp",
    "whois",
    "rdap",
    "rir",
    "irr",
    "arin",
    "ripe",
    "apnic",
    "afrinic",
    "lacnic",
    "asn",
    "bgp",
    "as-set",
    "abuse-contact",
    "network-operators"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dadepo/inet-registry-mcp.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node bin/choose-transport.js dev",
    "dev:stdio": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "tsx": "^4.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
